{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the system, potentially an admin.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "A reservation for visiting the model house.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who made the reservation" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "guests": { "type": "string" },
        "inquiry": { "type": "string" },
        "status": { "type": "string", "enum": ["대기", "완료", "취소"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "phone", "date", "time", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Store user profiles."
    },
    "reservations/{reservationId}": {
      "schema": { "$ref": "#/entities/Reservation" },
      "description": "Store all reservations."
    }
  }
}
